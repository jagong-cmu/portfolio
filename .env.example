# Copy to .env for local dev, and set the same vars in Vercel
# (Project → Settings → Environment Variables) for Production.

# Postgres connection string. For Vercel serverless, use a POOLED url
# (Neon/Supabase pooler or pgBouncer) to avoid exhausting connections.
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# NextAuth — required in production.
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET="..."
# The canonical site URL (no trailing slash). On Vercel: https://your-domain
NEXTAUTH_URL="http://localhost:3000"

# GitHub OAuth app (admin login).
# Callback URL must be: <NEXTAUTH_URL>/api/auth/callback/github
GITHUB_ID="..."
GITHUB_SECRET="..."

# Public site URL, used for metadata/OpenGraph. Same as NEXTAUTH_URL.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
